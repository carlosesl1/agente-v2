diff --git a/domain/turn_coordinator_adapter.py b/domain/turn_coordinator_adapter.py
new file mode 100644
index 0000000..461e891
--- /dev/null
+++ b/domain/turn_coordinator_adapter.py
@@ -0,0 +1,99 @@
+"""Thin dependency-injected seam from the runtime into Phase 7 TurnCoordinator."""
+
+from __future__ import annotations
+
+from collections.abc import Callable
+from typing import Protocol
+
+from reservation_boundary import (
+    InvalidIntent,
+    InvalidKernelDecision,
+    TurnCoordinator,
+    TurnDeadlineExceeded,
+    TurnEnvelope,
+    TurnEventConflict,
+    TurnImportRejected,
+    TurnPlan,
+)
+
+
+class TurnCoordinatorProtocol(Protocol):
+    def coordinate(self, envelope: TurnEnvelope) -> TurnPlan:
+        """Complete durable coordination before returning."""
+
+
+class TurnCoordinatorAdapterProtocol(Protocol):
+    def process_event(self, event: object) -> tuple[object, object]:
+        """Return the runtime response/decision pair."""
+
+
+class Phase7TurnCoordinatorAdapter:
+    """Marshal one event and enqueue only after durable coordination returns."""
+
+    def __init__(
+        self,
+        *,
+        coordinator: TurnCoordinatorProtocol,
+        envelope_factory: Callable[[object], TurnEnvelope],
+        result_factory: Callable[..., tuple[object, object, tuple[str, ...]]],
+        public_enqueue: Callable[..., object],
+    ) -> None:
+        if not callable(getattr(coordinator, "coordinate", None)):
+            raise TypeError("coordinator must expose coordinate")
+        for value, name in (
+            (envelope_factory, "envelope_factory"),
+            (result_factory, "result_factory"),
+            (public_enqueue, "public_enqueue"),
+        ):
+            if not callable(value):
+                raise TypeError(f"{name} must be callable")
+        self._coordinator = coordinator
+        self._envelope_factory = envelope_factory
+        self._result_factory = result_factory
+        self._public_enqueue = public_enqueue
+
+    @staticmethod
+    def _result(
+        value: object,
+    ) -> tuple[object, object, tuple[str, ...]]:
+        if type(value) is not tuple or len(value) != 3:
+            raise TypeError("result_factory must return an exact three-item tuple")
+        response, decision, chunks = value
+        if type(chunks) is not tuple or any(type(chunk) is not str or not chunk for chunk in chunks):
+            raise TypeError("result chunks must be exact nonempty strings")
+        return response, decision, chunks
+
+    def process_event(self, event: object) -> tuple[object, object]:
+        envelope = self._envelope_factory(event)
+        if type(envelope) is not TurnEnvelope:
+            raise TypeError("envelope_factory must return exact TurnEnvelope")
+        try:
+            plan = self._coordinator.coordinate(envelope)
+        except (
+            InvalidIntent,
+            InvalidKernelDecision,
+            TurnDeadlineExceeded,
+            TurnEventConflict,
+            TurnImportRejected,
+        ) as error:
+            response, decision, chunks = self._result(
+                self._result_factory(event=event, plan=None, error=error)
+            )
+            if chunks:
+                raise ValueError("failed/manual turn cannot enqueue public chunks")
+            return response, decision
+        if type(plan) is not TurnPlan:
+            raise TypeError("coordinator must return exact TurnPlan")
+        response, decision, chunks = self._result(
+            self._result_factory(event=event, plan=plan, error=None)
+        )
+        if chunks:
+            self._public_enqueue(event=event, plan=plan, chunks=chunks)
+        return response, decision
+
+
+__all__ = (
+    "Phase7TurnCoordinatorAdapter",
+    "TurnCoordinatorAdapterProtocol",
+    "TurnCoordinatorProtocol",
+)
