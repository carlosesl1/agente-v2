diff --git a/domain/tool_dispatch_adapter.py b/domain/tool_dispatch_adapter.py
new file mode 100644
index 0000000000000000000000000000000000000000..21d1a77a4f316b75364f984060026bf3d27ea56e
--- /dev/null
+++ b/domain/tool_dispatch_adapter.py
@@ -0,0 +1,316 @@
+"""Explicit Phase 7 ToolDispatch seam with legacy fallback outside boundary context."""
+
+from __future__ import annotations
+
+from collections.abc import Mapping
+from datetime import date, datetime, timezone
+from decimal import Decimal
+import json
+
+from reservation_boundary import (
+    ActivityDescriptionArguments,
+    ActivityReadArguments,
+    BoundaryState,
+    DateSlot,
+    DispatchKind,
+    FaqReadArguments,
+    IntegerSlot,
+    LodgingReadArguments,
+    RoomDescriptionArguments,
+    StateCommitArguments,
+    StringSlot,
+    ToolDispatch,
+    ToolDispatchRequest,
+    TypedFact,
+    from_wire_json,
+)
+from reservation_boundary.dispatch import CATALOG
+from reservation_boundary.types import CommandMigrationDisposition
+
+
+_DURABLE_WRITES = frozenset(
+    name
+    for name, contract in CATALOG.items()
+    if contract.command_migration in {
+        CommandMigrationDisposition.RESERVATION,
+        CommandMigrationDisposition.PAYMENT_SETTLEMENT,
+    }
+)
+_BLOCKED_WRITES = frozenset(
+    name
+    for name, contract in CATALOG.items()
+    if contract.command_migration is CommandMigrationDisposition.BLOCKED_UNMIGRATED
+)
+
+
+def load_native_tool_context() -> Mapping[str, object]:
+    """Load the existing plugin context lazily without importing provider code."""
+
+    from domain.chapada_native_tools import _load_context_from_env
+
+    context = _load_context_from_env()
+    return context if isinstance(context, Mapping) else {}
+
+
+def _base_result(
+    operation: str,
+    *,
+    status: str,
+    category: str,
+    manual_review: bool = False,
+) -> dict[str, object]:
+    result: dict[str, object] = {
+        "operation": operation,
+        "status": status,
+        "runtime_category": category,
+        "source": "phase7_tool_dispatch",
+        "provider_call_executed": False,
+        "side_effect_executed": False,
+        "safe_for_public_claims": False,
+        "raw_provider_payload_returned": False,
+    }
+    if manual_review:
+        result["requires_manual_review"] = True
+    return result
+
+
+def _exact_int(value: object, *, default: int = 0) -> int:
+    if value is None:
+        return default
+    if type(value) is not int:
+        raise TypeError("integer tool argument must be exact int")
+    return value
+
+
+def _exact_text(value: object, name: str) -> str:
+    if type(value) is not str or not value.strip():
+        raise TypeError(f"{name} must be a nonempty exact string")
+    return value.strip()
+
+
+def _date(value: object, name: str) -> date:
+    return date.fromisoformat(_exact_text(value, name))
+
+
+def _typed_read_arguments(name: str, arguments: Mapping[str, object]):
+    if name == "cerebro_consultar":
+        return FaqReadArguments(
+            _exact_text(arguments.get("query") or arguments.get("question"), "query"),
+            str(arguments.get("language") or "pt-BR"),
+        )
+    if name == "cloudbeds_consultar_hospedagem_v2":
+        return LodgingReadArguments(
+            _date(arguments.get("check_in"), "check_in"),
+            _date(arguments.get("check_out"), "check_out"),
+            _exact_int(arguments.get("adults"), default=1),
+            _exact_int(arguments.get("children"), default=0),
+        )
+    if name == "cloudbeds_descrever_quartos":
+        return RoomDescriptionArguments(
+            _exact_text(
+                arguments.get("room_id") or arguments.get("room_type_id"),
+                "room_type_id",
+            )
+        )
+    if name == "bokun_consultar_passeio_v2":
+        participants = sum(
+            _exact_int(arguments.get(key), default=0)
+            for key in ("adults", "children", "youth", "infants", "seniors")
+        )
+        return ActivityReadArguments(
+            _date(arguments.get("on_date") or arguments.get("date"), "date"),
+            max(1, participants),
+        )
+    if name == "bokun_consultar_descricao":
+        return ActivityDescriptionArguments(
+            _exact_text(
+                arguments.get("activity_id") or arguments.get("product_id"),
+                "product_id",
+            )
+        )
+    raise TypeError("unsupported read tool")
+
+
+def _state_commit_arguments(arguments: Mapping[str, object]) -> StateCommitArguments:
+    facts: list[TypedFact] = []
+    language = arguments.get("language")
+    if type(language) is str and language.strip():
+        facts.append(TypedFact("language", StringSlot(language.strip())))
+    services = arguments.get("desired_services")
+    if type(services) in (list, tuple) and services and type(services[0]) is str:
+        facts.append(TypedFact("service", StringSlot(services[0].strip())))
+    for key in ("adults", "children"):
+        value = arguments.get(key)
+        if type(value) is int:
+            facts.append(TypedFact(key, IntegerSlot(value)))
+    for source, target in (("check_in", "start_date"), ("check_out", "end_date")):
+        value = arguments.get(source)
+        if type(value) is str and value:
+            facts.append(TypedFact(target, DateSlot(date.fromisoformat(value))))
+    if not facts:
+        raise TypeError("state commit contains no whitelisted facts")
+    return StateCommitArguments(tuple(facts))
+
+
+def _deadline(context: Mapping[str, object]) -> datetime:
+    value = _exact_text(context.get("phase7_deadline"), "phase7_deadline")
+    parsed = datetime.fromisoformat(value)
+    if parsed.tzinfo is None or parsed.utcoffset() is None:
+        raise TypeError("phase7_deadline must be timezone-aware")
+    return parsed.astimezone(timezone.utc)
+
+
+def _boundary_state(context: Mapping[str, object]) -> BoundaryState:
+    wire = _exact_text(
+        context.get("phase7_boundary_state_wire"),
+        "phase7_boundary_state_wire",
+    )
+    state = from_wire_json(wire, BoundaryState)
+    lead_key = _exact_text(context.get("phase7_lead_key"), "phase7_lead_key")
+    if state.lead_key != lead_key:
+        raise ValueError("phase7 lead binding mismatch")
+    return state
+
+
+def _authorized_command_id(name: str, state: BoundaryState) -> str | None:
+    if name in {"cloudbeds_criar_reserva_v2", "bokun_agendar_passeio_v2"}:
+        workflow = state.workflow
+        command = getattr(workflow, "command", None)
+        operation = str(getattr(getattr(command, "operation", None), "value", ""))
+        expected = "reserve_lodging" if name.startswith("cloudbeds") else "book_activity"
+        if operation == expected:
+            return str(getattr(command, "command_id", "")) or None
+        return None
+    expected_unit = "hostel" if name.startswith("cloudbeds") else "agency"
+    for payment in state.payments:
+        command = getattr(payment, "settlement_command", None)
+        unit = str(
+            getattr(
+                getattr(payment.subject.confirmed_reservation_anchor, "business_unit", None),
+                "value",
+                "",
+            )
+        )
+        if command is not None and unit == expected_unit:
+            return str(getattr(command, "settlement_command_id", "")) or None
+    return None
+
+
+def dispatch_native_tool(
+    tool_name: object,
+    arguments: Mapping[str, object] | None,
+    *,
+    context: Mapping[str, object],
+    now: datetime | None = None,
+) -> dict[str, object]:
+    name = str(tool_name or "").strip()
+    if name not in CATALOG:
+        return _base_result(
+            name or "unknown",
+            status="phase7_rejected_unsupported_tool",
+            category="unknown",
+        )
+    contract = CATALOG[name]
+    category = "write" if contract.kind is DispatchKind.COMMAND else contract.kind.value
+    try:
+        state = _boundary_state(context)
+        deadline = _deadline(context)
+        instant = now if now is not None else datetime.now(timezone.utc)
+        if type(instant) is not datetime or instant.tzinfo is None or instant.utcoffset() is None:
+            raise TypeError("now must be timezone-aware")
+        if instant >= deadline:
+            return _base_result(
+                name,
+                status="phase7_deadline_exceeded",
+                category=category,
+                manual_review=contract.kind is DispatchKind.COMMAND,
+            )
+        event_id = _exact_text(context.get("phase7_event_id"), "phase7_event_id")
+        clean_arguments = arguments if isinstance(arguments, Mapping) else {}
+        if name in _BLOCKED_WRITES:
+            return _base_result(
+                name,
+                status="phase7_manual_review_unmigrated",
+                category=category,
+                manual_review=True,
+            )
+        if name in _DURABLE_WRITES:
+            command_id = _authorized_command_id(name, state)
+            if not command_id:
+                return _base_result(
+                    name,
+                    status="phase7_authorization_missing",
+                    category=category,
+                    manual_review=True,
+                )
+            result = _base_result(
+                name,
+                status="phase7_command_authorized",
+                category=category,
+            )
+            result["command_id"] = command_id
+            result["command_persisted"] = True
+            return result
+        typed_arguments = (
+            _state_commit_arguments(clean_arguments)
+            if contract.kind is DispatchKind.STATE_COMMIT
+            else _typed_read_arguments(name, clean_arguments)
+        )
+        request = ToolDispatchRequest(
+            name,
+            typed_arguments,
+            state.lead_key,
+            event_id,
+            deadline,
+        )
+        dispatch_result = ToolDispatch().dispatch(
+            request,
+            current_state=state,
+            now=instant,
+        )
+        if dispatch_result.kind is DispatchKind.READ:
+            return _base_result(
+                name,
+                status="phase7_read_request",
+                category=category,
+            )
+        result = _base_result(
+            name,
+            status="phase7_state_commit",
+            category=category,
+        )
+        result["fact_names"] = [fact.name for fact in dispatch_result.facts]
+        return result
+    except (TypeError, ValueError) as error:
+        result = _base_result(
+            name,
+            status="phase7_invalid_boundary_context",
+            category=category,
+            manual_review=contract.kind is DispatchKind.COMMAND,
+        )
+        result["error_type"] = error.__class__.__name__
+        return result
+
+
+def dispatch_hermes_native_tool(
+    tool_name: object,
+    arguments: Mapping[str, object] | None = None,
+) -> str:
+    context = load_native_tool_context()
+    if not context.get("phase7_boundary_state_wire"):
+        from domain.chapada_native_tools import execute_hermes_native_tool
+
+        return execute_hermes_native_tool(str(tool_name or ""), arguments)
+    result = dispatch_native_tool(
+        tool_name,
+        arguments,
+        context=context,
+    )
+    return json.dumps(result, ensure_ascii=False, sort_keys=True)
+
+
+__all__ = (
+    "dispatch_hermes_native_tool",
+    "dispatch_native_tool",
+    "load_native_tool_context",
+)
diff --git a/domain/turn_coordinator_adapter.py b/domain/turn_coordinator_adapter.py
new file mode 100644
index 0000000000000000000000000000000000000000..461e89150c83e1a0aee2e1f00ee60539b3027514
--- /dev/null
+++ b/domain/turn_coordinator_adapter.py
@@ -0,0 +1,99 @@
+"""Thin dependency-injected seam from the runtime into Phase 7 TurnCoordinator."""
+
+from __future__ import annotations
+
+from collections.abc import Callable
+from typing import Protocol
+
+from reservation_boundary import (
+    InvalidIntent,
+    InvalidKernelDecision,
+    TurnCoordinator,
+    TurnDeadlineExceeded,
+    TurnEnvelope,
+    TurnEventConflict,
+    TurnImportRejected,
+    TurnPlan,
+)
+
+
+class TurnCoordinatorProtocol(Protocol):
+    def coordinate(self, envelope: TurnEnvelope) -> TurnPlan:
+        """Complete durable coordination before returning."""
+
+
+class TurnCoordinatorAdapterProtocol(Protocol):
+    def process_event(self, event: object) -> tuple[object, object]:
+        """Return the runtime response/decision pair."""
+
+
+class Phase7TurnCoordinatorAdapter:
+    """Marshal one event and enqueue only after durable coordination returns."""
+
+    def __init__(
+        self,
+        *,
+        coordinator: TurnCoordinatorProtocol,
+        envelope_factory: Callable[[object], TurnEnvelope],
+        result_factory: Callable[..., tuple[object, object, tuple[str, ...]]],
+        public_enqueue: Callable[..., object],
+    ) -> None:
+        if not callable(getattr(coordinator, "coordinate", None)):
+            raise TypeError("coordinator must expose coordinate")
+        for value, name in (
+            (envelope_factory, "envelope_factory"),
+            (result_factory, "result_factory"),
+            (public_enqueue, "public_enqueue"),
+        ):
+            if not callable(value):
+                raise TypeError(f"{name} must be callable")
+        self._coordinator = coordinator
+        self._envelope_factory = envelope_factory
+        self._result_factory = result_factory
+        self._public_enqueue = public_enqueue
+
+    @staticmethod
+    def _result(
+        value: object,
+    ) -> tuple[object, object, tuple[str, ...]]:
+        if type(value) is not tuple or len(value) != 3:
+            raise TypeError("result_factory must return an exact three-item tuple")
+        response, decision, chunks = value
+        if type(chunks) is not tuple or any(type(chunk) is not str or not chunk for chunk in chunks):
+            raise TypeError("result chunks must be exact nonempty strings")
+        return response, decision, chunks
+
+    def process_event(self, event: object) -> tuple[object, object]:
+        envelope = self._envelope_factory(event)
+        if type(envelope) is not TurnEnvelope:
+            raise TypeError("envelope_factory must return exact TurnEnvelope")
+        try:
+            plan = self._coordinator.coordinate(envelope)
+        except (
+            InvalidIntent,
+            InvalidKernelDecision,
+            TurnDeadlineExceeded,
+            TurnEventConflict,
+            TurnImportRejected,
+        ) as error:
+            response, decision, chunks = self._result(
+                self._result_factory(event=event, plan=None, error=error)
+            )
+            if chunks:
+                raise ValueError("failed/manual turn cannot enqueue public chunks")
+            return response, decision
+        if type(plan) is not TurnPlan:
+            raise TypeError("coordinator must return exact TurnPlan")
+        response, decision, chunks = self._result(
+            self._result_factory(event=event, plan=plan, error=None)
+        )
+        if chunks:
+            self._public_enqueue(event=event, plan=plan, chunks=chunks)
+        return response, decision
+
+
+__all__ = (
+    "Phase7TurnCoordinatorAdapter",
+    "TurnCoordinatorAdapterProtocol",
+    "TurnCoordinatorProtocol",
+)
diff --git a/tests/test_phase7_tool_dispatch_adapter.py b/tests/test_phase7_tool_dispatch_adapter.py
new file mode 100644
index 0000000000000000000000000000000000000000..7b2f6ea9707bcc7aaa79ed79031688d87acffe74
--- /dev/null
+++ b/tests/test_phase7_tool_dispatch_adapter.py
@@ -0,0 +1,193 @@
+"""Phase 7 runtime ToolDispatch seam for all 13 active tools."""
+
+from __future__ import annotations
+
+from datetime import datetime, timedelta, timezone
+import ast
+import json
+from pathlib import Path
+
+import pytest
+
+from reservation_boundary import import_legacy_state, to_wire_json
+from reservation_boundary.properties import synthetic_collecting_snapshot
+
+from domain.tool_dispatch_adapter import (
+    dispatch_hermes_native_tool,
+    dispatch_native_tool,
+)
+
+
+T0 = datetime(2026, 7, 20, 12, 0, tzinfo=timezone.utc)
+ROOT = Path(__file__).resolve().parents[1]
+
+READ_REQUESTS = {
+    "cerebro_consultar": {"query": "Qual é o horário?", "language": "pt-BR"},
+    "cloudbeds_consultar_hospedagem_v2": {
+        "check_in": "2026-08-20",
+        "check_out": "2026-08-22",
+        "adults": 2,
+        "children": 0,
+    },
+    "cloudbeds_descrever_quartos": {"room_type_id": "room-synthetic-001"},
+    "bokun_consultar_passeio_v2": {
+        "date": "2026-08-21",
+        "adults": 2,
+        "children": 0,
+    },
+    "bokun_consultar_descricao": {"product_id": "activity-synthetic-001"},
+}
+DURABLE_WRITES = {
+    "cloudbeds_criar_reserva_v2",
+    "bokun_agendar_passeio_v2",
+    "cloudbeds_lancar_pagamento_confirmar_reserva",
+    "bokun_lancar_pagamento_confirmar_reserva",
+}
+BLOCKED_WRITES = {
+    "wise_verificar_pagamento",
+    "cloudbeds_gerar_link_pagamento_stripe",
+    "bokun_gerar_link_pagamento_stripe",
+}
+
+
+def phase7_context():
+    state = import_legacy_state(synthetic_collecting_snapshot()).state
+    assert state is not None
+    return {
+        "phase7_boundary_state_wire": to_wire_json(state),
+        "phase7_lead_key": state.lead_key,
+        "phase7_event_id": "event-runtime-dispatch-001",
+        "phase7_deadline": datetime(2099, 7, 20, 12, 1, tzinfo=timezone.utc).isoformat(),
+    }
+
+
+def test_all_five_reads_become_typed_requests_without_provider_call():
+    context = phase7_context()
+    for name, arguments in READ_REQUESTS.items():
+        result = dispatch_native_tool(name, arguments, context=context, now=T0)
+        assert result["operation"] == name
+        assert result["status"] == "phase7_read_request"
+        assert result["runtime_category"] == "read"
+        assert result["provider_call_executed"] is False
+        assert result["side_effect_executed"] is False
+        assert result["safe_for_public_claims"] is False
+
+
+def test_four_durable_writes_require_existing_authorized_command():
+    context = phase7_context()
+    for name in DURABLE_WRITES:
+        result = dispatch_native_tool(name, {}, context=context, now=T0)
+        assert result["operation"] == name
+        assert result["status"] == "phase7_authorization_missing"
+        assert result["runtime_category"] == "write"
+        assert result["provider_call_executed"] is False
+        assert result["side_effect_executed"] is False
+        assert result["requires_manual_review"] is True
+
+
+def test_three_unmigrated_writes_are_explicit_manual_review():
+    context = phase7_context()
+    for name in BLOCKED_WRITES:
+        result = dispatch_native_tool(name, {}, context=context, now=T0)
+        assert result["operation"] == name
+        assert result["status"] == "phase7_manual_review_unmigrated"
+        assert result["runtime_category"] == "write"
+        assert result["provider_call_executed"] is False
+        assert result["side_effect_executed"] is False
+        assert result["requires_manual_review"] is True
+
+
+def test_state_commit_returns_only_whitelisted_typed_facts():
+    result = dispatch_native_tool(
+        "chapada_commit_state",
+        {
+            "language": "pt-BR",
+            "desired_services": ["hostel"],
+            "adults": 2,
+            "selected_offer_id": "must-not-become-a-fact",
+            "payment_confirmed": True,
+        },
+        context=phase7_context(),
+        now=T0,
+    )
+    assert result["status"] == "phase7_state_commit"
+    assert result["runtime_category"] == "state_commit"
+    assert result["provider_call_executed"] is False
+    assert set(result["fact_names"]) == {"adults", "language", "service"}
+    assert "selected_offer_id" not in result["fact_names"]
+    assert "payment_confirmed" not in result["fact_names"]
+
+
+def test_unknown_alias_and_expired_deadline_fail_closed():
+    context = phase7_context()
+    unknown = dispatch_native_tool("cloudbeds_consultar_disponibilidade", {}, context=context, now=T0)
+    assert unknown["status"] == "phase7_rejected_unsupported_tool"
+    assert unknown["provider_call_executed"] is False
+
+    expired = dict(context)
+    expired["phase7_deadline"] = (T0 - timedelta(seconds=1)).isoformat()
+    result = dispatch_native_tool(
+        "cerebro_consultar",
+        READ_REQUESTS["cerebro_consultar"],
+        context=expired,
+        now=T0,
+    )
+    assert result["status"] == "phase7_deadline_exceeded"
+    assert result["provider_call_executed"] is False
+
+
+def test_plugin_has_one_dispatch_entrypoint_and_no_direct_executor_symbol():
+    plugin = (ROOT / ".hermes/plugins/chapada_leads_tools/__init__.py").read_text()
+    assert "from domain.tool_dispatch_adapter import dispatch_hermes_native_tool" in plugin
