+def phase7_context(tmp_path, fixture=None):
+    state = import_legacy_state(synthetic_collecting_snapshot()).state
+    assert state is not None
+    if fixture is not None:
+        state = from_wire_json(BOUNDARY_FIXTURES[fixture]["wire"], BoundaryState)
+    event_id = "event-runtime-dispatch-001"
+    state = replace(state, version=1, processed_event_ids=(event_id,))
+    store_path = tmp_path / f"phase7-{fixture or 'collecting'}-{len(tuple(tmp_path.glob('*.db')))}.db"
+    store = SQLiteBoundaryStore.open_path(store_path)
+    workflow_command = getattr(state.workflow, "command", None)
+    command = (
+        workflow_command
+        if workflow_command is not None
+        else state.payments[0].settlement_command
+        if state.payments
+        else None
+    )
+    instant = T0.isoformat()
+    store._connection.execute(
+        "INSERT INTO boundary_state "
+        "(lead_key,version,state_json,state_hash,fencing_token,created_at,updated_at) "
+        "VALUES (?,?,?,?,0,?,?)",
+        (state.lead_key, state.version, to_wire_json(state), semantic_hash(state), instant, instant),
+    )
+    store._connection.execute(
+        "INSERT INTO boundary_events "
+        "(lead_key,event_id,event_hash,commit_hash,state_version,occurred_at) "
+        "VALUES (?,?,?,?,?,?)",
+        (state.lead_key, event_id, "a" * 64, "b" * 64, state.version, instant),
+    )
+    if command is not None:
+        command_id, command_type, command_json = _command_record(command)
+        store._connection.execute(
+            "INSERT INTO boundary_commands "
+            "(command_id,lead_key,event_id,command_type,command_json,command_hash,created_at) "
+            "VALUES (?,?,?,?,?,?,?)",
+            (
+                command_id,
+                state.lead_key,
+                event_id,
+                command_type,
+                command_json,
+                hashlib.sha256(command_json.encode()).hexdigest(),
+                instant,
+            ),
+        )
+    receiver_profiles = {}
+    if state.payments:
+        receiver_profiles["Synthetic Receiver"] = (
+            state.payments[0].verified_evidence.evidence.proof_receiver_profile_id
+        )
+    store.close()
+    return {
+        "phase7_boundary_state_wire": to_wire_json(state),
+        "phase7_lead_key": state.lead_key,
+        "phase7_event_id": event_id,
+        "phase7_deadline": datetime(2099, 7, 20, 12, 1, tzinfo=timezone.utc).isoformat(),
+        "phase7_store_path": str(store_path),
+        "phase7_receiver_profiles": receiver_profiles,
+    }
+
+
+def test_all_five_reads_become_typed_requests_without_provider_call(tmp_path):
+    context = phase7_context(tmp_path)
+    for name, arguments in READ_REQUESTS.items():
+        result = dispatch_native_tool(name, arguments, context=context, now=T0)
+        assert result["operation"] == name
+        assert result["status"] == "phase7_read_request"
+        assert result["runtime_category"] == "read"
+        assert result["provider_call_executed"] is False
+        assert result["side_effect_executed"] is False
+        assert result["safe_for_public_claims"] is False
+
+
+def test_four_durable_writes_require_existing_authorized_command(tmp_path):
+    context = phase7_context(tmp_path)
+    for name in DURABLE_WRITES:
+        result = dispatch_native_tool(name, {}, context=context, now=T0)
+        assert result["operation"] == name
+        assert result["status"] == "phase7_invalid_boundary_context"
+        assert result["runtime_category"] == "write"
+        assert result["provider_call_executed"] is False
+        assert result["side_effect_executed"] is False
+        assert result["requires_manual_review"] is True
+
+
+def test_four_durable_writes_cross_typed_dispatch_with_active_schemas(tmp_path):
+    for name, fixture in (
+        ("cloudbeds_criar_reserva_v2", "lodging_reservation"),
+        ("bokun_agendar_passeio_v2", "activity_reservation"),
+    ):
+        data = BOUNDARY_FIXTURES[fixture]
+        result = dispatch_native_tool(
+            name,
+            {"option": {"option_id": data["offer_id"]}, "answers": {}},
+            context=phase7_context(tmp_path, fixture),
+            now=T0,
+        )
+        assert result["status"] == "phase7_command_authorized"
+        assert result["command_id"] == data["command_id"]
+        assert result["command_persisted"] is True
+        forged = dispatch_native_tool(
+            name,
+            {"option": {"option_id": "offer-forged"}, "answers": {}},
+            context=phase7_context(tmp_path, fixture),
+            now=T0,
+        )
+        assert forged["status"] == "phase7_invalid_boundary_context"
+        missing_row = phase7_context(tmp_path, fixture)
+        store = SQLiteBoundaryStore.open_path(Path(missing_row["phase7_store_path"]))
+        store._connection.execute("DELETE FROM boundary_commands")
+        store.close()
+        unpersisted = dispatch_native_tool(
+            name,
+            {"option": {"option_id": data["offer_id"]}, "answers": {}},
+            context=missing_row,
+            now=T0,
+        )
+        assert unpersisted["status"] == "phase7_invalid_boundary_context"
+        assert unpersisted.get("command_persisted") is not True
+
+    for name, fixture, anchor_key in (
+        ("cloudbeds_lancar_pagamento_confirmar_reserva", "hostel_payment", "reservation_id"),
+        ("bokun_lancar_pagamento_confirmar_reserva", "agency_payment", "confirmation_code"),
+    ):
+        data = BOUNDARY_FIXTURES[fixture]
+        arguments = {
+            "confirmation_by_lead": True,
+            "payment_proof_received": True,
+            "payment_method": "pix",
+            anchor_key: data["anchor_id"],
+            "transaction_id": data["evidence_id"],
+            "proof_amount": data["amount"],
+            "proof_receiver_name": "Synthetic Receiver",
+            "proof_payment_status": "completed",
+        }
+        result = dispatch_native_tool(
+            name,
+            arguments,
+            context=phase7_context(tmp_path, fixture),
+            now=T0,
+        )
+        assert result["status"] == "phase7_command_authorized"
+        assert result["command_id"] == data["command_id"]
+        forged = dispatch_native_tool(
+            name,
+            {**arguments, "proof_amount": "999.99"},
+            context=phase7_context(tmp_path, fixture),
+            now=T0,
+        )
+        assert forged["status"] == "phase7_invalid_boundary_context"
+        for field, value in (
+            ("proof_receiver_name", "FORGED RECEIVER"),
+            ("proof_payment_status", "forged"),
+        ):
+            forged_proof = dispatch_native_tool(
+                name,
+                {**arguments, field: value},
+                context=phase7_context(tmp_path, fixture),
+                now=T0,
+            )
+            assert forged_proof["status"] == "phase7_invalid_boundary_context"
+
+        missing_row = phase7_context(tmp_path, fixture)
+        store = SQLiteBoundaryStore.open_path(Path(missing_row["phase7_store_path"]))
+        store._connection.execute("DELETE FROM boundary_commands")
+        store.close()
+        unpersisted = dispatch_native_tool(name, arguments, context=missing_row, now=T0)
+        assert unpersisted["status"] == "phase7_invalid_boundary_context"
+        assert unpersisted.get("command_persisted") is not True
+
+
+def test_three_unmigrated_writes_are_explicit_manual_review(tmp_path):
+    context = phase7_context(tmp_path)
+    for name in BLOCKED_WRITES:
+        result = dispatch_native_tool(name, {}, context=context, now=T0)
+        assert result["operation"] == name
+        assert result["status"] == "phase7_manual_review_unmigrated"
+        assert result["runtime_category"] == "write"
+        assert result["provider_call_executed"] is False
+        assert result["side_effect_executed"] is False
