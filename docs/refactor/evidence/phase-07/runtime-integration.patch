diff --git a/qa/phase7_regression_support.py b/qa/phase7_regression_support.py
new file mode 100644
index 0000000..69fb550
--- /dev/null
+++ b/qa/phase7_regression_support.py
@@ -0,0 +1,53 @@
+"""Explicit regression-only adapter for pre-Phase-7 webhook behavior tests.
+
+Production ``create_app`` never constructs this adapter. Tests that still verify the
+legacy runtime must opt in through this module, keeping the active ingress fail-closed.
+"""
+
+from __future__ import annotations
+
+from dataclasses import replace
+from typing import Any
+
+import app as app_module
+
+
+class LegacyRegressionTurnAdapter:
+    def __init__(self) -> None:
+        self._bound: dict[str, Any] | None = None
+
+    def bind(self, api: Any) -> None:
+        state = api.state
+        self._bound = {
+            "settings": state.settings,
+            "lead_repository": state.lead_repository,
+            "shadow_log": state.shadow_log,
+            "manychat_client": state.manychat_client,
+            "email_notifier": state.email_notifier,
+            "public_message_outbox": state.public_message_outbox,
+            "agent_config": state.agent_config,
+            "planner": state.planner,
+        }
+
+    def process_event(self, event: Any):
+        if self._bound is None:
+            raise RuntimeError("legacy regression adapter is not bound")
+        message_ids = tuple(part for part in str(event.message_id).split("+") if part)
+        source_keys = tuple(
+            replace(event, message_id=message_id).idempotency_key
+            for message_id in message_ids
+        )
+        return app_module._process_legacy_event_for_regression_tests(
+            event,
+            source_idempotency_keys=source_keys,
+            **self._bound,
+        )
+
+
+def create_app(*args: Any, **kwargs: Any):
+    if kwargs.get("phase7_turn_adapter") is not None:
+        raise ValueError("regression helper owns phase7_turn_adapter")
+    adapter = LegacyRegressionTurnAdapter()
+    api = app_module.create_app(*args, phase7_turn_adapter=adapter, **kwargs)
+    adapter.bind(api)
+    return api
