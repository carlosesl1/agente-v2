+"""Phase 7 runtime ToolDispatch seam for all 13 active tools."""
+
+from __future__ import annotations
+
+from datetime import datetime, timedelta, timezone
+import ast
+import json
+from pathlib import Path
+
+import pytest
+
+from reservation_boundary import import_legacy_state, to_wire_json
+from reservation_boundary.properties import synthetic_collecting_snapshot
+
+from domain.tool_dispatch_adapter import (
+    dispatch_hermes_native_tool,
+    dispatch_native_tool,
+)
+
+
+T0 = datetime(2026, 7, 20, 12, 0, tzinfo=timezone.utc)
+ROOT = Path(__file__).resolve().parents[1]
+
+READ_REQUESTS = {
+    "cerebro_consultar": {"query": "Qual é o horário?", "language": "pt-BR"},
+    "cloudbeds_consultar_hospedagem_v2": {
+        "check_in": "2026-08-20",
+        "check_out": "2026-08-22",
+        "adults": 2,
+        "children": 0,
+    },
+    "cloudbeds_descrever_quartos": {"room_type_id": "room-synthetic-001"},
+    "bokun_consultar_passeio_v2": {
+        "date": "2026-08-21",
+        "adults": 2,
+        "children": 0,
+    },
+    "bokun_consultar_descricao": {"product_id": "activity-synthetic-001"},
+}
+DURABLE_WRITES = {
+    "cloudbeds_criar_reserva_v2",
+    "bokun_agendar_passeio_v2",
+    "cloudbeds_lancar_pagamento_confirmar_reserva",
+    "bokun_lancar_pagamento_confirmar_reserva",
+}
+BLOCKED_WRITES = {
+    "wise_verificar_pagamento",
+    "cloudbeds_gerar_link_pagamento_stripe",
+    "bokun_gerar_link_pagamento_stripe",
+}
+
+
+def phase7_context():
+    state = import_legacy_state(synthetic_collecting_snapshot()).state
+    assert state is not None
+    return {
+        "phase7_boundary_state_wire": to_wire_json(state),
+        "phase7_lead_key": state.lead_key,
+        "phase7_event_id": "event-runtime-dispatch-001",
+        "phase7_deadline": datetime(2099, 7, 20, 12, 1, tzinfo=timezone.utc).isoformat(),
+    }
+
+
+def test_all_five_reads_become_typed_requests_without_provider_call():
+    context = phase7_context()
+    for name, arguments in READ_REQUESTS.items():
+        result = dispatch_native_tool(name, arguments, context=context, now=T0)
+        assert result["operation"] == name
+        assert result["status"] == "phase7_read_request"
+        assert result["runtime_category"] == "read"
+        assert result["provider_call_executed"] is False
+        assert result["side_effect_executed"] is False
+        assert result["safe_for_public_claims"] is False
+
+
+def test_four_durable_writes_require_existing_authorized_command():
+    context = phase7_context()
+    for name in DURABLE_WRITES:
+        result = dispatch_native_tool(name, {}, context=context, now=T0)
+        assert result["operation"] == name
+        assert result["status"] == "phase7_authorization_missing"
+        assert result["runtime_category"] == "write"
+        assert result["provider_call_executed"] is False
+        assert result["side_effect_executed"] is False
+        assert result["requires_manual_review"] is True
+
+
+def test_three_unmigrated_writes_are_explicit_manual_review():
+    context = phase7_context()
+    for name in BLOCKED_WRITES:
+        result = dispatch_native_tool(name, {}, context=context, now=T0)
+        assert result["operation"] == name
+        assert result["status"] == "phase7_manual_review_unmigrated"
+        assert result["runtime_category"] == "write"
+        assert result["provider_call_executed"] is False
+        assert result["side_effect_executed"] is False
+        assert result["requires_manual_review"] is True
+
+
+def test_state_commit_returns_only_whitelisted_typed_facts():
+    result = dispatch_native_tool(
+        "chapada_commit_state",
+        {
+            "language": "pt-BR",
+            "desired_services": ["hostel"],
+            "adults": 2,
+            "selected_offer_id": "must-not-become-a-fact",
+            "payment_confirmed": True,
+        },
+        context=phase7_context(),
+        now=T0,
+    )
+    assert result["status"] == "phase7_state_commit"
+    assert result["runtime_category"] == "state_commit"
+    assert result["provider_call_executed"] is False
+    assert set(result["fact_names"]) == {"adults", "language", "service"}
+    assert "selected_offer_id" not in result["fact_names"]
+    assert "payment_confirmed" not in result["fact_names"]
+
+
+def test_unknown_alias_and_expired_deadline_fail_closed():
+    context = phase7_context()
+    unknown = dispatch_native_tool("cloudbeds_consultar_disponibilidade", {}, context=context, now=T0)
+    assert unknown["status"] == "phase7_rejected_unsupported_tool"
+    assert unknown["provider_call_executed"] is False
+
+    expired = dict(context)
+    expired["phase7_deadline"] = (T0 - timedelta(seconds=1)).isoformat()
+    result = dispatch_native_tool(
+        "cerebro_consultar",
+        READ_REQUESTS["cerebro_consultar"],
+        context=expired,
+        now=T0,
+    )
+    assert result["status"] == "phase7_deadline_exceeded"
+    assert result["provider_call_executed"] is False
+
+
+def test_plugin_has_one_dispatch_entrypoint_and_no_direct_executor_symbol():
+    plugin = (ROOT / ".hermes/plugins/chapada_leads_tools/__init__.py").read_text()
+    assert "from domain.tool_dispatch_adapter import dispatch_hermes_native_tool" in plugin
+    assert "print(dispatch_hermes_native_tool(tool_name, arguments))" in plugin
+    subprocess_code = plugin.split('_TOOL_SUBPROCESS_CODE = """', 1)[1].split('"""', 1)[0]
+    assert "execute_hermes_native_tool" not in subprocess_code
+    assert subprocess_code.count("dispatch_hermes_native_tool") == 2
+
+
+def test_no_boundary_context_uses_legacy_fallback_but_phase7_never_does(monkeypatch):
+    import domain.chapada_native_tools as legacy
+    import domain.tool_dispatch_adapter as adapter_module
+
+    calls = []
+    monkeypatch.setattr(adapter_module, "load_native_tool_context", lambda: {})
+    monkeypatch.setattr(
+        legacy,
+        "execute_hermes_native_tool",
+        lambda name, arguments: calls.append((name, arguments)) or json.dumps({"status": "legacy"}),
+    )
+    assert json.loads(dispatch_hermes_native_tool("cerebro_consultar", {"query": "x"}))["status"] == "legacy"
+    assert calls == [("cerebro_consultar", {"query": "x"})]
+
+    monkeypatch.setattr(adapter_module, "load_native_tool_context", phase7_context)
+    calls.clear()
+    result = json.loads(dispatch_hermes_native_tool("cerebro_consultar", READ_REQUESTS["cerebro_consultar"]))
+    assert result["status"] == "phase7_read_request"
+    assert calls == []
+
+
+def test_phase7_path_bypasses_legacy_runner_tool_budget_and_executor():
+    source = (ROOT / "app.py").read_text()
+    tree = ast.parse(source)
+    process = next(node for node in tree.body if isinstance(node, ast.FunctionDef) and node.name == "_process_event")
+    first_statement = process.body[0]
+    assert isinstance(first_statement, ast.If)
+    assert "phase7_turn_adapter is not None" in ast.unparse(first_statement.test)
+    branch = ast.unparse(first_statement)
+    assert "phase7_turn_adapter.process_event(event)" in branch
+    assert "NativeHermesAgentRunner" not in branch
+    assert "ToolExecutor" not in branch
+
+    adapter_tree = ast.parse((ROOT / "domain/tool_dispatch_adapter.py").read_text())
+    imported = {
+        alias.name
+        for node in adapter_tree.body
+        if isinstance(node, ast.Import)
+        for alias in node.names
+    }
+    imported.update(
+        node.module
+        for node in adapter_tree.body
+        if isinstance(node, ast.ImportFrom) and node.module
+    )
+    assert not any(name.startswith(("services", "tools", "subprocess", "requests")) for name in imported)
