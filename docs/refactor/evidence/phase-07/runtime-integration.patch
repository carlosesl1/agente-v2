diff --git a/domain/tool_dispatch_adapter.py b/domain/tool_dispatch_adapter.py
new file mode 100644
index 0000000..8a8d30f
--- /dev/null
+++ b/domain/tool_dispatch_adapter.py
@@ -0,0 +1,418 @@
+"""Explicit Phase 7 ToolDispatch seam with legacy fallback outside boundary context."""
+
+from __future__ import annotations
+
+from collections.abc import Mapping
+from datetime import date, datetime, timezone
+from decimal import Decimal
+import json
+from pathlib import Path
+
+from reservation_boundary import (
+    ActivityDescriptionArguments,
+    ActivityPaymentArguments,
+    ActivityReadArguments,
+    ActivityReservationArguments,
+    BoundaryState,
+    DateSlot,
+    DecimalSlot,
+    DispatchKind,
+    FaqReadArguments,
+    IntegerSlot,
+    LodgingReadArguments,
+    LodgingPaymentArguments,
+    LodgingReservationArguments,
+    RoomDescriptionArguments,
+    SQLiteBoundaryStore,
+    StateCommitArguments,
+    StringSlot,
+    ToolDispatch,
+    ToolDispatchRequest,
+    TypedFact,
+    from_wire_json,
+)
+from reservation_boundary.dispatch import CATALOG
+from reservation_boundary.types import CommandMigrationDisposition
+
+
+_DURABLE_WRITES = frozenset(
+    name
+    for name, contract in CATALOG.items()
+    if contract.command_migration in {
+        CommandMigrationDisposition.RESERVATION,
+        CommandMigrationDisposition.PAYMENT_SETTLEMENT,
+    }
+)
+_BLOCKED_WRITES = frozenset(
+    name
+    for name, contract in CATALOG.items()
+    if contract.command_migration is CommandMigrationDisposition.BLOCKED_UNMIGRATED
+)
+
+
+def load_native_tool_context() -> Mapping[str, object]:
+    """Load the existing plugin context lazily without importing provider code."""
+
+    from domain.chapada_native_tools import _load_context_from_env
+
+    context = _load_context_from_env()
+    return context if isinstance(context, Mapping) else {}
+
+
+def _base_result(
+    operation: str,
+    *,
+    status: str,
+    category: str,
+    manual_review: bool = False,
+) -> dict[str, object]:
+    result: dict[str, object] = {
+        "operation": operation,
+        "status": status,
+        "runtime_category": category,
+        "source": "phase7_tool_dispatch",
+        "provider_call_executed": False,
+        "side_effect_executed": False,
+        "safe_for_public_claims": False,
+        "raw_provider_payload_returned": False,
+    }
+    if manual_review:
+        result["requires_manual_review"] = True
+    return result
+
+
+def _exact_int(value: object, *, default: int = 0) -> int:
+    if value is None:
+        return default
+    if type(value) is not int:
+        raise TypeError("integer tool argument must be exact int")
+    return value
+
+
+def _exact_text(value: object, name: str) -> str:
+    if type(value) is not str or not value.strip():
+        raise TypeError(f"{name} must be a nonempty exact string")
+    return value.strip()
+
+
+def _date(value: object, name: str) -> date:
+    return date.fromisoformat(_exact_text(value, name))
+
+
+def _typed_read_arguments(name: str, arguments: Mapping[str, object]):
+    if name == "cerebro_consultar":
+        return FaqReadArguments(
+            _exact_text(arguments.get("query") or arguments.get("question"), "query"),
+            str(arguments.get("language") or "pt-BR"),
+        )
+    if name == "cloudbeds_consultar_hospedagem_v2":
+        return LodgingReadArguments(
+            _date(arguments.get("check_in"), "check_in"),
+            _date(arguments.get("check_out"), "check_out"),
+            _exact_int(arguments.get("adults"), default=1),
+            _exact_int(arguments.get("children"), default=0),
+        )
+    if name == "cloudbeds_descrever_quartos":
+        return RoomDescriptionArguments(
+            _exact_text(
+                arguments.get("room_id") or arguments.get("room_type_id"),
+                "room_type_id",
+            )
+        )
+    if name == "bokun_consultar_passeio_v2":
+        participants = sum(
+            _exact_int(arguments.get(key), default=0)
+            for key in ("adults", "children", "youth", "infants", "seniors")
+        )
+        return ActivityReadArguments(
+            _exact_text(arguments.get("tour_product_id"), "tour_product_id"),
+            _date(arguments.get("date_start"), "date_start"),
+            max(1, participants),
+        )
+    if name == "bokun_consultar_descricao":
+        return ActivityDescriptionArguments(
+            _exact_text(
+                arguments.get("activity_id") or arguments.get("product_id"),
+                "product_id",
+            )
+        )
+    raise TypeError("unsupported read tool")
+
+
+def _state_commit_arguments(arguments: Mapping[str, object]) -> StateCommitArguments:
+    facts: list[TypedFact] = []
+    slots = arguments.get("collected_slots")
+    if slots is None:
+        slots = {}
+    if not isinstance(slots, Mapping):
+        raise TypeError("collected_slots must be a mapping")
+    language = slots.get("language")
+    if type(language) is str and language.strip():
+        facts.append(TypedFact("language", StringSlot(language.strip())))
+    services = arguments.get("desired_services")
+    if type(services) in (list, tuple) and services and type(services[0]) is str:
+        facts.append(TypedFact("service", StringSlot(services[0].strip())))
+    for key in ("adults", "children"):
+        value = slots.get(key)
+        if type(value) is int:
+            facts.append(TypedFact(key, IntegerSlot(value)))
+    for source, target in (("check_in", "start_date"), ("check_out", "end_date")):
+        value = slots.get(source)
+        if type(value) is str and value:
+            facts.append(TypedFact(target, DateSlot(date.fromisoformat(value))))
+    if not facts:
+        raise TypeError("state commit contains no whitelisted facts")
+    return StateCommitArguments(tuple(facts))
+
+
+def _canonical_amount(value: object) -> DecimalSlot:
+    text = _exact_text(value, "proof_amount")
+    amount = Decimal(text)
+    if not amount.is_finite() or amount <= 0:
+        raise ValueError("proof_amount must be finite and positive")
+    return DecimalSlot(format(amount.quantize(Decimal("0.01")), "f"))
+
+
+def _typed_command_arguments(
+    name: str,
+    arguments: Mapping[str, object],
+    state: BoundaryState,
+    context: Mapping[str, object],
+):
+    if name in {"cloudbeds_criar_reserva_v2", "bokun_agendar_passeio_v2"}:
+        option = arguments.get("option")
+        answers = arguments.get("answers")
+        if not isinstance(option, Mapping) or not isinstance(answers, Mapping):
+            raise TypeError("reservation option and answers must be mappings")
+        offer_id = _exact_text(option.get("option_id"), "option.option_id")
+        workflow = state.workflow
+        command = getattr(workflow, "command", None)
+        version = getattr(command, "draft_version", None)
+        signature = getattr(command, "subject_signature", None)
+        if type(version) is not int or type(signature) is not str:
+            raise ValueError("reservation command binding is unavailable")
+        argument_type = (
+            LodgingReservationArguments
+            if name == "cloudbeds_criar_reserva_v2"
+            else ActivityReservationArguments
+        )
+        return argument_type(offer_id, version, signature)
+
+    if arguments.get("confirmation_by_lead") is not True:
+        raise ValueError("payment requires exact lead confirmation")
+    if arguments.get("payment_proof_received") is not True:
+        raise ValueError("payment requires proof receipt")
+    method = arguments.get("payment_method")
+    if method is not None and str(method).casefold() != "pix":
+        raise ValueError("settlement adapter accepts only the active Pix schema")
+    status = _exact_text(arguments.get("proof_payment_status"), "proof_payment_status").casefold()
+    if status not in {"paid", "completed", "concluido", "concluído"}:
+        raise ValueError("payment proof status is not mechanically completed")
+    receiver_name = _exact_text(arguments.get("proof_receiver_name"), "proof_receiver_name")
+    receiver_profiles = context.get("phase7_receiver_profiles")
+    if not isinstance(receiver_profiles, Mapping):
+        raise ValueError("receiver profile resolver is unavailable")
+    receiver_profile_id = _exact_text(
+        receiver_profiles.get(receiver_name),
+        "receiver_profile_id",
+    )
+    anchor_key = "reservation_id" if name.startswith("cloudbeds") else "confirmation_code"
+    anchor_id = _exact_text(arguments.get(anchor_key), anchor_key)
+    evidence_id = _exact_text(arguments.get("transaction_id"), "transaction_id")
+    amount = _canonical_amount(arguments.get("proof_amount") or arguments.get("amount"))
+    expected_unit = "hostel" if name.startswith("cloudbeds") else "agency"
+    matches = tuple(
+        payment
+        for payment in state.payments
+        if payment.subject.confirmed_reservation_anchor.payment_target_id == anchor_id
+        and payment.subject.confirmed_reservation_anchor.business_unit.value == expected_unit
+    )
+    if len(matches) != 1:
+        raise ValueError("payment target does not bind one boundary workflow")
+    argument_type = (
+        LodgingPaymentArguments
+        if name.startswith("cloudbeds")
+        else ActivityPaymentArguments
+    )
+    return argument_type(
+        anchor_id,
+        evidence_id,
+        amount,
+        matches[0].subject.currency,
+        receiver_profile_id,
+        "paid",
+    )
+
+
+def _deadline(context: Mapping[str, object]) -> datetime:
+    value = _exact_text(context.get("phase7_deadline"), "phase7_deadline")
+    parsed = datetime.fromisoformat(value)
+    if parsed.tzinfo is None or parsed.utcoffset() is None:
+        raise TypeError("phase7_deadline must be timezone-aware")
+    return parsed.astimezone(timezone.utc)
+
+
+def _boundary_state(context: Mapping[str, object]) -> tuple[BoundaryState, Path]:
+    wire = _exact_text(
+        context.get("phase7_boundary_state_wire"),
+        "phase7_boundary_state_wire",
+    )
+    state = from_wire_json(wire, BoundaryState)
+    lead_key = _exact_text(context.get("phase7_lead_key"), "phase7_lead_key")
+    if state.lead_key != lead_key:
+        raise ValueError("phase7 lead binding mismatch")
+    store_path = Path(_exact_text(context.get("phase7_store_path"), "phase7_store_path"))
+    store = SQLiteBoundaryStore.open_readonly(store_path)
+    try:
+        persisted = store.load_state(lead_key)
+    finally:
+        store.close()
+    if persisted.state != state:
+        raise ValueError("phase7 state wire does not bind the durable row")
+    return state, store_path
+
+
+def dispatch_native_tool(
+    tool_name: object,
+    arguments: Mapping[str, object] | None,
+    *,
+    context: Mapping[str, object],
+    now: datetime | None = None,
+) -> dict[str, object]:
+    name = str(tool_name or "").strip()
+    if name not in CATALOG:
+        return _base_result(
+            name or "unknown",
+            status="phase7_rejected_unsupported_tool",
+            category="unknown",
+        )
+    contract = CATALOG[name]
+    category = "write" if contract.kind is DispatchKind.COMMAND else contract.kind.value
+    try:
+        state, store_path = _boundary_state(context)
+        deadline = _deadline(context)
+        instant = now if now is not None else datetime.now(timezone.utc)
+        if type(instant) is not datetime or instant.tzinfo is None or instant.utcoffset() is None:
+            raise TypeError("now must be timezone-aware")
+        if instant >= deadline:
+            return _base_result(
+                name,
+                status="phase7_deadline_exceeded",
+                category=category,
+                manual_review=contract.kind is DispatchKind.COMMAND,
+            )
+        event_id = _exact_text(context.get("phase7_event_id"), "phase7_event_id")
+        clean_arguments = arguments if isinstance(arguments, Mapping) else {}
+        if name in _BLOCKED_WRITES:
+            return _base_result(
+                name,
+                status="phase7_manual_review_unmigrated",
+                category=category,
+                manual_review=True,
+            )
+        typed_arguments = (
+            _state_commit_arguments(clean_arguments)
+            if contract.kind is DispatchKind.STATE_COMMIT
+            else _typed_command_arguments(name, clean_arguments, state, context)
+            if name in _DURABLE_WRITES
+            else _typed_read_arguments(name, clean_arguments)
+        )
+        request = ToolDispatchRequest(
+            name,
+            typed_arguments,
+            state.lead_key,
+            event_id,
+            deadline,
+        )
+        dispatch_result = ToolDispatch().dispatch(
+            request,
+            current_state=state,
+            now=instant,
+        )
+        if dispatch_result.kind is DispatchKind.READ:
+            return _base_result(
+                name,
+                status="phase7_read_request",
+                category=category,
+            )
+        if dispatch_result.kind is DispatchKind.COMMAND:
+            if len(dispatch_result.commands) != 1:
+                raise ValueError("durable write did not resolve one exact command")
+            command = dispatch_result.commands[0]
+            command_id = getattr(command, "command_id", None) or getattr(
+                command,
+                "settlement_command_id",
+                None,
+            )
+            store = SQLiteBoundaryStore.open_readonly(store_path)
+            try:
+                persisted = store.command_is_persisted(
+                    lead_key=state.lead_key,
+                    event_id=event_id,
+                    command=command,
+                )
+            finally:
+                store.close()
+            if not persisted:
+                raise ValueError("authorized command is not durably persisted")
+            result = _base_result(
+                name,
+                status="phase7_command_authorized",
+                category=category,
+            )
+            result["command_id"] = _exact_text(command_id, "command_id")
+            result["command_persisted"] = True
+            return result
+        result = _base_result(
+            name,
+            status="phase7_state_commit",
+            category=category,
+        )
+        result["fact_names"] = [fact.name for fact in dispatch_result.facts]
+        return result
+    except (TypeError, ValueError) as error:
+        result = _base_result(
+            name,
+            status="phase7_invalid_boundary_context",
+            category=category,
+            manual_review=contract.kind is DispatchKind.COMMAND,
+        )
+        result["error_type"] = error.__class__.__name__
+        return result
+
+
+def dispatch_hermes_native_tool(
+    tool_name: object,
+    arguments: Mapping[str, object] | None = None,
+) -> str:
+    context = load_native_tool_context()
+    if not context.get("phase7_boundary_state_wire"):
+        name = str(tool_name or "").strip()
+        contract = CATALOG.get(name)
+        category = (
+            "unknown"
+            if contract is None
+            else "write"
+            if contract.kind is DispatchKind.COMMAND
+            else contract.kind.value
+        )
+        result = _base_result(
+            name or "unknown",
+            status="phase7_boundary_context_required",
+            category=category,
+            manual_review=contract is not None and contract.kind is DispatchKind.COMMAND,
+        )
+        return json.dumps(result, ensure_ascii=False, sort_keys=True)
+    result = dispatch_native_tool(
+        tool_name,
+        arguments,
+        context=context,
+    )
+    return json.dumps(result, ensure_ascii=False, sort_keys=True)
+
+
+__all__ = (
+    "dispatch_hermes_native_tool",
+    "dispatch_native_tool",
+    "load_native_tool_context",
+)
