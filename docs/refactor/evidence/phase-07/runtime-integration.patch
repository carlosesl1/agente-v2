+"""Phase 7 runtime adapter seam over the installed boundary wheel."""
+
+from __future__ import annotations
+
+from contextlib import contextmanager
+from datetime import datetime, timedelta, timezone
+from types import SimpleNamespace
+
+import app as app_module
+import pytest
+
+from reservation_boundary import (
+    BoundaryState,
+    ConversationIntent,
+    ConversationIntentKind,
+    ImportDisposition,
+    KernelDecision,
+    SQLiteBoundaryStore,
+    ToolDispatchRequest,
+    TurnCoordinator,
+    TurnEnvelope,
+    TurnPlan,
+    TurnPlanReason,
+    import_legacy_state,
+)
+from reservation_boundary.properties import synthetic_collecting_snapshot
+
+from domain.turn_coordinator_adapter import Phase7TurnCoordinatorAdapter
+
+
+T0 = datetime(2026, 7, 20, 12, 0, tzinfo=timezone.utc)
+
+
+class FixedClock:
+    def __init__(self, now=T0):
+        self.value = now
+
+    def now(self):
+        return self.value
+
+
+class RecordingLock:
+    def __init__(self, trace):
+        self.trace = trace
+        self.claims = 0
+
+    @contextmanager
+    def claim(self, **kwargs):
+        self.claims += 1
+        self.trace.append("claim")
+        yield
+
+
+class LegacyReader:
+    def __init__(self, trace, snapshot):
+        self.trace = trace
+        self.snapshot = snapshot
+        self.reads = 0
+
+    def read_snapshot(self, lead_key):
+        self.reads += 1
+        self.trace.append("legacy_read")
+        assert lead_key == self.snapshot.raw_fields["lead_key"]
+        return self.snapshot
+
+
+class Importer:
+    def __init__(self, trace):
+        self.trace = trace
+        self.calls = 0
+
+    def import_snapshot(self, snapshot):
+        self.calls += 1
+        self.trace.append("import")
+        return import_legacy_state(snapshot)
+
+
+class IntentPort:
+    def __init__(self, trace):
+        self.trace = trace
+        self.calls = 0
+
+    def interpret(self, request):
+        self.calls += 1
+        self.trace.append("intent")
+        return ConversationIntent(
+            ConversationIntentKind.INFORM,
+            request.source_event_id,
+        )
+
+
+class KernelPort:
+    def __init__(self, trace):
+        self.trace = trace
+        self.calls = 0
+
+    def reduce(self, state, intent):
+        self.calls += 1
+        self.trace.append("reduce")
+        return KernelDecision(state, (), (), (), ())
+
+
+class TracingStore:
+    def __init__(self, trace, inner):
+        self.trace = trace
+        self.inner = inner
+        self.genesis = 0
+        self.commits = 0
+
+    def event_hash(self, *args):
+        self.trace.append("event_lookup")
+        return self.inner.event_hash(*args)
+
+    def load_state(self, *args):
+        self.trace.append("typed_load")
+        return self.inner.load_state(*args)
+
+    def import_genesis(self, *args, **kwargs):
+        self.genesis += 1
+        self.trace.append("typed_genesis")
+        return self.inner.import_genesis(*args, **kwargs)
+
+    def acquire_fence(self, *args):
+        self.trace.append("fence")
+        return self.inner.acquire_fence(*args)
+
+    def commit(self, **kwargs):
+        self.commits += 1
+        self.trace.append("commit")
+        return self.inner.commit(**kwargs)
+
+
+class ResultFactory:
+    def __init__(self, trace, *, chunks=("safe response",)):
+        self.trace = trace
+        self.chunks = chunks
+        self.errors = []
+
+    def __call__(self, *, event, plan, error):
+        self.trace.append("compose")
+        if error is not None:
+            self.errors.append(error)
+            return (
+                {"reply": "A equipe vai revisar seu atendimento."},
+                SimpleNamespace(route="handoff", reply_type="handoff"),
+                (),
+            )
+        return (
+            {"reply": "safe response"},
+            SimpleNamespace(route="hostel", reply_type="text"),
+            self.chunks,
+        )
+
+
+class Queue:
+    def __init__(self, trace):
+        self.trace = trace
+        self.calls = []
+
+    def __call__(self, *, event, plan, chunks):
+        self.trace.append("enqueue")
+        self.calls.append((event, plan, chunks))
+
+
+def envelope(*, lead_key="lead-synthetic-000000", deadline=T0 + timedelta(minutes=1)):
+    return TurnEnvelope(
+        lead_key,
+        "event-phase7-runtime-001",
+        app_module.NormalizedMessage("olá", "pt-BR") if hasattr(app_module, "NormalizedMessage") else __import__("reservation_boundary").NormalizedMessage("olá", "pt-BR"),
+        T0,
+        deadline,
+    )
+
+
+def coordinator_fixture(snapshot, *, now=T0):
+    trace = []
+    inner = SQLiteBoundaryStore.open_memory()
+    store = TracingStore(trace, inner)
+    lock = RecordingLock(trace)
+    reader = LegacyReader(trace, snapshot)
+    importer = Importer(trace)
+    intent = IntentPort(trace)
+    kernel = KernelPort(trace)
+    coordinator = TurnCoordinator(
+        lock=lock,
+        store=store,
+        legacy_reader=reader,
+        importer=importer,
+        intent=intent,
+        kernel=kernel,
+        clock=FixedClock(now),
+    )
+    return trace, inner, store, lock, reader, importer, intent, kernel, coordinator
+
+
+def test_process_event_persists_before_public_delivery():
+    trace = []
+    state = import_legacy_state(synthetic_collecting_snapshot()).state
+    assert state is not None
+    plan = TurnPlan(state, (), (), (), False, TurnPlanReason.COMPLETED)
+
+    class Coordinator:
+        def coordinate(self, request):
+            trace.extend(("claim", "load", "intent", "reduce", "commit"))
+            return plan
+
+    factory = ResultFactory(trace)
+    queue = Queue(trace)
+    adapter = Phase7TurnCoordinatorAdapter(
+        coordinator=Coordinator(),
+        envelope_factory=lambda event: envelope(),
+        result_factory=factory,
+        public_enqueue=queue,
+    )
+    result = adapter.process_event(object())
+    assert result[0]["reply"] == "safe response"
+    assert trace == ["claim", "load", "intent", "reduce", "commit", "compose", "enqueue"]
+    assert trace.index("commit") < trace.index("enqueue")
+
+
+def test_legacy_state_is_read_once_never_written_and_typed_genesis_is_single():
+    snapshot = synthetic_collecting_snapshot()
+    trace, inner, store, lock, reader, importer, intent, kernel, coordinator = coordinator_fixture(snapshot)
+    queue = Queue(trace)
+    adapter = Phase7TurnCoordinatorAdapter(
+        coordinator=coordinator,
+        envelope_factory=lambda event: envelope(),
+        result_factory=ResultFactory(trace),
+        public_enqueue=queue,
+    )
+    try:
+        adapter.process_event(object())
+        assert reader.reads == 1
+        assert not {"write", "upsert", "delete"}.intersection(dir(reader))
+        assert importer.calls == 1
+        assert store.genesis == 1
+        assert store.commits == 1
+        assert intent.calls == 1 and kernel.calls == 1
+        assert inner.load_state("lead-synthetic-000000").version == 1
+        assert len(queue.calls) == 1
+        assert trace.index("commit") < trace.index("enqueue")
+    finally:
+        inner.close()
+
+
+def test_nonmigrable_state_handoffs_without_public_fact_claim_or_enqueue():
+    baseline = synthetic_collecting_snapshot()
+    raw = dict(baseline.raw_fields)
+    raw["metadata"] = {}
+    import hashlib, json
+    canonical = json.dumps(raw, ensure_ascii=False, sort_keys=True, separators=(",", ":"))
+    from reservation_boundary import LegacyLeadSnapshot
+    snapshot = LegacyLeadSnapshot(
+        1,
+        "chapada-leads-hermes",
+        raw,
+        canonical,
+        hashlib.sha256(canonical.encode()).hexdigest(),
+    )
+    trace, inner, store, lock, reader, importer, intent, kernel, coordinator = coordinator_fixture(snapshot)
+    queue = Queue(trace)
+    factory = ResultFactory(trace)
+    adapter = Phase7TurnCoordinatorAdapter(
+        coordinator=coordinator,
+        envelope_factory=lambda event: envelope(),
+        result_factory=factory,
+        public_enqueue=queue,
+    )
+    try:
+        response, decision = adapter.process_event(object())
+        assert decision.route == "handoff"
+        public = response["reply"].casefold()
+        assert not any(token in public for token in ("preço", "disponibilidade", "reserva confirmada", "pagamento confirmado"))
+        assert queue.calls == []
+        assert store.commits == 0
+        assert intent.calls == 0 and kernel.calls == 0
+        assert len(factory.errors) == 1
+    finally:
+        inner.close()
+
+
+def test_deadline_expiry_has_zero_intent_kernel_provider_and_manychat_calls():
+    snapshot = synthetic_collecting_snapshot()
+    trace, inner, store, lock, reader, importer, intent, kernel, coordinator = coordinator_fixture(
+        snapshot,
+        now=T0 + timedelta(minutes=2),
+    )
+    queue = Queue(trace)
+    factory = ResultFactory(trace)
+    adapter = Phase7TurnCoordinatorAdapter(
+        coordinator=coordinator,
+        envelope_factory=lambda event: envelope(deadline=T0 + timedelta(minutes=1)),
+        result_factory=factory,
+        public_enqueue=queue,
+    )
+    try:
+        adapter.process_event(object())
+        assert lock.claims == 0
+        assert reader.reads == 0 and importer.calls == 0
+        assert intent.calls == 0 and kernel.calls == 0
+        assert queue.calls == []
+        assert store.genesis == 0 and store.commits == 0
+    finally:
+        inner.close()
+
