tmp_path = PosixPath('/tmp/pytest-of-hermeswebui/pytest-58/test_four_durable_writes_cross0')

    def test_four_durable_writes_cross_typed_dispatch_with_active_schemas(tmp_path):
        for name, fixture in (
            ("cloudbeds_criar_reserva_v2", "lodging_reservation"),
            ("bokun_agendar_passeio_v2", "activity_reservation"),
        ):
            data = BOUNDARY_FIXTURES[fixture]
            result = dispatch_native_tool(
                name,
                {"option": {"option_id": data["offer_id"]}, "answers": {}},
                context=phase7_context(tmp_path, fixture),
                now=T0,
            )
            assert result["status"] == "phase7_command_authorized"
            assert result["command_id"] == data["command_id"]
            assert result["command_persisted"] is True
            forged = dispatch_native_tool(
                name,
                {"option": {"option_id": "offer-forged"}, "answers": {}},
                context=phase7_context(tmp_path, fixture),
                now=T0,
            )
            assert forged["status"] == "phase7_invalid_boundary_context"
            missing_row = phase7_context(tmp_path, fixture)
            store = SQLiteBoundaryStore.open_path(Path(missing_row["phase7_store_path"]))
            store._connection.execute("DELETE FROM boundary_commands")
            store.close()
            unpersisted = dispatch_native_tool(
                name,
                {"option": {"option_id": data["offer_id"]}, "answers": {}},
                context=missing_row,
                now=T0,
            )
>           assert unpersisted["status"] == "phase7_invalid_boundary_context"
