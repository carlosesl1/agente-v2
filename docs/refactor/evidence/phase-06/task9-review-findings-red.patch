+                (PaymentEffectKind.INTERNAL_PAYMENT_EMAIL, False),
+                (PaymentEffectKind.BOOKING_FORM, True),
+            ),
+        )
+        for job in jobs:
+            self.assertEqual(from_wire_json(to_wire_json(job), PaymentEffectJob), job)
