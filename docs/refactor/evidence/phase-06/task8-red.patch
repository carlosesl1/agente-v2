+class PaymentClaimStoreCase(unittest.TestCase):
+    def setUp(self) -> None:
+        self.temporary = tempfile.TemporaryDirectory(prefix="phase6-task8-")
+        self.addCleanup(self.temporary.cleanup)
+        self.path = Path(self.temporary.name) / "followup.db"
+        self.store = SQLiteFollowupUnitOfWork.open(self.path)
+        self.addCleanup(self.store.close)
+
+    def ready(self, *, suffix="one", method=PaymentMethod.PIX, evidence=None, anchor=None):
+        selected_anchor = anchor or confirmed_anchor()
+        selected_evidence = evidence or evidence_for(
+            method,
+            target=selected_anchor.payment_target_id,
+            identity=suffix,
+        )
+        return prepare_payment(
+            self.store,
+            suffix=suffix,
+            method=method,
+            evidence=selected_evidence,
+            anchor=selected_anchor,
+        )
+
+    def accept(self, *, suffix="one", method=PaymentMethod.PIX, evidence=None, anchor=None):
+        state, event = self.ready(
+            suffix=suffix,
+            method=method,
+            evidence=evidence,
+            anchor=anchor,
+        )
+        transition = self.store.claim_payment_evidence(
+            state.subject.payment_id,
+            3,
+            event,
+        )
+        return transition, event
+
+    def claim(self, *, worker_id="worker:settlement:one", now=NOW):
+        return self.store.claim_settlement(
+            worker_id=worker_id,
+            now=now,
+            lease_ttl=LEASE_TTL,
+        )
+
