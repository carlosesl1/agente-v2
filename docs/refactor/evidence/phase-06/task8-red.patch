+def payment_fingerprint(connection: sqlite3.Connection) -> tuple[tuple[object, ...], ...]:
+    return tuple(
+        tuple(connection.execute(f"SELECT * FROM main.{table} ORDER BY 1"))
+        for table in PAYMENT_TABLES
+    )
+
+
+def task8_counts(connection: sqlite3.Connection) -> tuple[int, int, int]:
+    return tuple(
+        connection.execute(f"SELECT COUNT(*) FROM main.{table}").fetchone()[0]
+        for table in (
+            "payment_evidence_claims",
+            "payment_commands",
+            "payment_ledger",
+        )
+    )
+
