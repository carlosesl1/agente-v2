+
+    def test_pre_fence_retry_budget_is_finite_and_tokens_never_regress(self) -> None:
+        claims = []
+        dispositions = []
+        evidence_statuses = []
+        current_now = NOW
+        for attempt in range(3):
+            claim = self.claim(
+                worker_id=f"worker:settlement:retry:{attempt}",
+                now=current_now,
+            )
+            claims.append(claim)
+            disposition = self.store.release_pre_dispatch_settlement(
+                claim,
+                retryable=True,
+                now=current_now + timedelta(seconds=1),
+            )
+            dispositions.append(disposition.value)
+            evidence_statuses.append(
+                self.store.load_evidence_claim(
+                    claim.command.evidence_claim_key
+                ).status.value
+            )
+            current_now += timedelta(seconds=2)
+        self.assertEqual(
+            [claim.lease.fencing_token for claim in claims],
+            [1, 2, 3],
+        )
+        self.assertEqual([claim.claim_count for claim in claims], [1, 2, 3])
+        self.assertEqual(
+            dispositions,
+            ["requeued", "requeued", "terminal_not_dispatched"],
+        )
+        self.assertEqual(
+            evidence_statuses,
+            ["retryable", "retryable", "completed"],
+        )
+        self.assertIsNone(self.claim(now=current_now))
+        row = self.store._connection.execute(
+            "SELECT status, fencing_token, claim_count, dispatch_slots_consumed, "
+            "outcome_certainty FROM main.payment_ledger"
+        ).fetchone()
+        self.assertEqual(row, ("outcome_recorded", 3, 3, 0, "not_dispatched"))
+        evidence_claim = self.store.load_evidence_claim(claims[-1].command.evidence_claim_key)
+        self.assertEqual(evidence_claim.status.value, "completed")
+        self.assertIsNotNone(evidence_claim.consumed_at)
+
+    def test_fence_consumes_exactly_slot_one_permanently_without_dispatching(self) -> None:
+        claim = self.claim()
+        permit = self.store.fence_settlement(
+            claim,
+            claim.command.canonical_payload,
+            now=NOW + timedelta(seconds=1),
+        )
+        self.assertEqual(permit.dispatch_slot, 1)
+        self.assertEqual(permit.command, claim.command)
+        self.assertEqual(
+            permit.request_hash,
+            hashlib.sha256(claim.command.canonical_payload.encode("utf-8")).hexdigest(),
+        )
+        row = self.store._connection.execute(
+            "SELECT status, dispatch_slots_consumed, dispatch_request_hash, "
+            "dispatch_fenced_at FROM main.payment_ledger"
+        ).fetchone()
+        self.assertEqual(row[0:2], ("dispatch_fenced", 1))
+        self.assertEqual(row[2], permit.request_hash)
+        self.assertEqual(row[3], permit.fenced_at.isoformat())
+        with self.assertRaises(StoreError):
+            self.store.fence_settlement(
+                claim,
+                claim.command.canonical_payload,
+                now=NOW + timedelta(seconds=2),
+            )
+        with self.assertRaises(StaleLease):
+            self.store.release_pre_dispatch_settlement(
+                claim,
+                retryable=True,
+                now=NOW + timedelta(seconds=2),
+            )
