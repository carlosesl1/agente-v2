+def prepare_payment(
+    store: SQLiteFollowupUnitOfWork,
+    *,
+    suffix: str,
+    method: PaymentMethod,
+    evidence,
+    anchor=None,
+):
+    opened = store.open_payment(anchor or confirmed_anchor(), payment_effect_policy())
+    payment_id = opened.state.subject.payment_id
+    selected = store.apply_payment(
+        payment_id,
+        0,
+        PaymentMethodSelected(
+            event_id=f"payment:event:claims:{suffix}:method",
+            payment_id=payment_id,
+            method=method,
+            selected_at=T0 + timedelta(seconds=1),
+        ),
+    )
+    summarized = store.apply_payment(
+        payment_id,
+        1,
+        FinancialSummaryRecorded(
+            event_id=f"payment:event:claims:{suffix}:summary",
+            subject=selected.state.subject,
+            summary_hash=financial_summary_hash(selected.state.subject),
+            recorded_at=T0 + timedelta(seconds=2),
+        ),
+    )
+    confirmed = store.apply_payment(
+        payment_id,
+        2,
+        FinancialConfirmationReceived(
+            event_id=f"payment:event:claims:{suffix}:confirmation",
+            payment_id=payment_id,
+            payment_version=summarized.state.subject.payment_version,
+            economic_signature=summarized.state.subject.economic_signature,
+            summary_hash=summarized.state.summary.summary_hash,
+            confirmation_id=f"payment:confirmation:claims:{suffix}",
+            confirmed_at=T0 + timedelta(seconds=3),
+        ),
+    )
+    event = PaymentEvidenceRecorded(
+        event_id=f"payment:event:claims:{suffix}:evidence",
+        payment_id=payment_id,
+        payment_version=confirmed.state.subject.payment_version,
+        economic_signature=confirmed.state.subject.economic_signature,
+        evidence=evidence,
+        trust=payment_evidence_trust(),
+        recorded_at=T0 + timedelta(seconds=4),
+    )
+    return confirmed.state, event
+
+
+def alternate_anchor(suffix: str, **changes: object):
+    values: dict[str, object] = {
+        "reservation_workflow_id": f"workflow:reservation:claims:{suffix}",
+        "payment_target_id": f"target:reservation:claims:{suffix}",
+    }
+    values.update(changes)
+    return confirmed_anchor(**values)
+
+
+def evidence_for(method: PaymentMethod, *, target: str, identity: str = "shared"):
+    if method is PaymentMethod.PIX:
+        return pix_visual_evidence()
+    if method is PaymentMethod.WISE:
+        baseline = wise_credit(
+            transaction_fingerprint=hashlib.sha256(
+                f"wise-credit:{identity}".encode("utf-8")
+            ).hexdigest(),
+            reference_fingerprint=wise_target_fingerprint(target),
+        )
+        return baseline
+    if method is PaymentMethod.STRIPE:
+        return stripe_event(
+            event_id="evt_7YGh3Kp9Qm2Vx8Nz4T",
+            payment_intent_fingerprint=stripe_target_fingerprint(target),
+        )
+    raise AssertionError("closed test method")
+
