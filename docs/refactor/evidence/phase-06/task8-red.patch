+        shared = pix_visual_evidence()
+        first, _ = self.accept(suffix="pix-first", evidence=shared)
+        self.assertIs(first.state.status, PaymentStatus.SETTLEMENT_QUEUED)
+        before = task8_counts(self.store._connection)
+        candidates = (
+            alternate_anchor("pix-target"),
+            alternate_anchor("pix-unit", business_unit=BusinessUnit.AGENCY),
+        )
+        for index, anchor in enumerate(candidates):
+            state, event = self.ready(
+                suffix=f"pix-conflict-{index}",
+                evidence=shared,
+                anchor=anchor,
+            )
+            with self.subTest(anchor=anchor.payment_target_id), self.assertRaises(
+                IdentityConflict
+            ):
+                self.store.claim_payment_evidence(state.subject.payment_id, 3, event)
+            self.assertEqual(task8_counts(self.store._connection), before)
+            self.assertIs(
+                self.store.load_payment(state.subject.payment_id).status,
+                PaymentStatus.AWAITING_EVIDENCE,
+            )
