+    def test_command_payload_and_hash_tamper_fail_before_claim(self) -> None:
+        def tamper_closed_target(connection: sqlite3.Connection) -> None:
+            raw = connection.execute(
+                "SELECT command_json FROM main.payment_commands"
+            ).fetchone()[0]
+            payload = json.loads(raw)
+            payload["data"]["canonical_payload"] = json.dumps(
+                {
+                    **json.loads(payload["data"]["canonical_payload"]),
+                    "payment_target_id": "target:reservation:claims:tampered",
+                },
+                ensure_ascii=False,
+                sort_keys=True,
+                separators=(",", ":"),
+                allow_nan=False,
+            )
+            tampered = json.dumps(
+                payload,
+                ensure_ascii=False,
+                sort_keys=True,
+                separators=(",", ":"),
+                allow_nan=False,
+            )
+            connection.execute(
+                "UPDATE main.payment_commands SET command_json=?, command_hash=?",
+                (tampered, hashlib.sha256(tampered.encode("utf-8")).hexdigest()),
+            )
+
+        mutations = (
+            lambda connection: connection.execute(
+                "UPDATE main.payment_commands SET command_json='{}', "
+                "command_hash='0' || substr(command_hash, 2)"
+            ),
+            lambda connection: connection.execute(
+                "UPDATE main.payment_commands SET command_hash="
+                "CASE substr(command_hash, 1, 1) WHEN 'f' THEN 'e' ELSE 'f' END "
+                "|| substr(command_hash, 2)"
+            ),
+            tamper_closed_target,
+        )
+        for index, mutate in enumerate(mutations):
+            with self.subTest(index=index):
+                path = Path(self.temporary.name) / f"command-tamper-{index}.db"
+                self.store.close()
+                self.store = SQLiteFollowupUnitOfWork.open(path)
+                self.transition, self.event = self.accept(suffix=f"command-{index}")
+                mutate(self.store._connection)
+                before = payment_fingerprint(self.store._connection)
+                with self.assertRaises(DataCorruption):
+                    self.claim(worker_id=f"worker:settlement:command:{index}")
+                self.assertEqual(payment_fingerprint(self.store._connection), before)
