+    def test_stale_owner_token_count_and_expiry_cannot_release_or_fence(self) -> None:
+        claim = self.claim()
+        forged = (
+            replace(claim, lease=replace(claim.lease, owner="worker:settlement:forged")),
+            replace(
+                claim,
+                lease=replace(
+                    claim.lease,
+                    fencing_token=claim.lease.fencing_token + 1,
+                ),
+                claim_count=claim.claim_count + 1,
+            ),
+        )
+        before = payment_fingerprint(self.store._connection)
+        for candidate in forged:
+            with self.subTest(candidate=candidate), self.assertRaises(StaleLease):
+                self.store.release_pre_dispatch_settlement(
+                    candidate,
+                    retryable=True,
+                    now=NOW + timedelta(seconds=1),
+                )
+            with self.assertRaises(StaleLease):
