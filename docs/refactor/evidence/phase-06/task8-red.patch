+    def test_exact_expiry_is_reclaimable_only_before_fence(self) -> None:
+        first = self.claim(worker_id="worker:settlement:first")
+        self.assertIsNone(
+            self.claim(
+                worker_id="worker:settlement:early",
+                now=NOW + timedelta(seconds=29),
+            )
+        )
+        second = self.claim(
+            worker_id="worker:settlement:second",
+            now=first.lease.expires_at,
+        )
+        self.assertEqual(second.command, first.command)
+        self.assertEqual(second.lease.fencing_token, first.lease.fencing_token + 1)
+        self.assertEqual(second.claim_count, first.claim_count + 1)
+        with self.assertRaises(StaleLease):
+            self.store.release_pre_dispatch_settlement(
+                first,
+                retryable=True,
+                now=first.lease.expires_at,
+            )
+        with self.assertRaises(StaleLease):
+            self.store.fence_settlement(
+                first,
+                first.command.canonical_payload,
+                now=first.lease.expires_at,
+            )
