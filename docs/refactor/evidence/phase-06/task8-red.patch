+class Phase6PaymentAtomicityAndContentionTests(PaymentClaimStoreCase):
+    def test_claim_command_ledger_and_workflow_event_are_one_transaction(self) -> None:
+        fault_targets = (
+            ("payment_evidence_claims", "INSERT", ""),
+            ("payment_commands", "INSERT", ""),
+            ("payment_ledger", "INSERT", ""),
+            ("payment_events", "INSERT", " WHEN NEW.event_type='PaymentEvidenceRecorded'"),
+            ("payment_workflows", "UPDATE", ""),
+        )
+        for index, (table, operation, when) in enumerate(fault_targets):
+            with self.subTest(table=table):
+                path = Path(self.temporary.name) / f"atomic-{index}.db"
+                store = SQLiteFollowupUnitOfWork.open(path)
+                try:
+                    state, event = prepare_payment(
+                        store,
+                        suffix=f"atomic-{index}",
+                        method=PaymentMethod.PIX,
+                        evidence=pix_visual_evidence(),
+                    )
+                    before = payment_fingerprint(store._connection)
+                    store._connection.execute(
+                        f"CREATE TEMP TRIGGER task8_fault_{index} BEFORE {operation} "
+                        f"ON main.{table}{when} BEGIN SELECT RAISE(ABORT, 'task8:{index}'); END"
+                    )
+                    with self.assertRaises(StoreError):
+                        store.claim_payment_evidence(
+                            state.subject.payment_id,
+                            3,
+                            event,
+                        )
+                    self.assertEqual(payment_fingerprint(store._connection), before)
+                    self.assertEqual(task8_counts(store._connection), (0, 0, 0))
+                finally:
+                    store.close()
+                reopened = SQLiteFollowupUnitOfWork.open(path)
+                try:
+                    self.assertEqual(task8_counts(reopened._connection), (0, 0, 0))
+                    self.assertIs(
+                        reopened.load_payment(state.subject.payment_id).status,
+                        PaymentStatus.AWAITING_EVIDENCE,
+                    )
+                    self.assertEqual(reopened._connection.execute("PRAGMA quick_check").fetchone(), ("ok",))
+                    self.assertEqual(reopened._connection.execute("PRAGMA foreign_key_check").fetchall(), [])
+                finally:
+                    reopened.close()
+
+    def test_real_two_connection_contention_has_one_global_winner(self) -> None:
+        for round_index in range(10):
+            with self.subTest(round=round_index):
+                path = Path(self.temporary.name) / f"contention-{round_index}.db"
+                setup = SQLiteFollowupUnitOfWork.open(path)
+                shared = pix_visual_evidence()
+                first_anchor = alternate_anchor(f"contention-{round_index}-a")
+                second_anchor = alternate_anchor(f"contention-{round_index}-b")
+                first_state, first_event = prepare_payment(
+                    setup,
+                    suffix=f"contention-{round_index}-a",
+                    method=PaymentMethod.PIX,
+                    evidence=shared,
+                    anchor=first_anchor,
+                )
+                second_state, second_event = prepare_payment(
+                    setup,
+                    suffix=f"contention-{round_index}-b",
+                    method=PaymentMethod.PIX,
+                    evidence=shared,
+                    anchor=second_anchor,
+                )
+                setup.close()
+                barrier = Barrier(2)
+
+                def contender(payment_id, event):
+                    store = SQLiteFollowupUnitOfWork.open(path)
+                    try:
+                        barrier.wait(timeout=5)
+                        store.claim_payment_evidence(payment_id, 3, event)
+                        return "won"
+                    except IdentityConflict:
+                        return "conflict"
+                    finally:
+                        store.close()
+
+                with ThreadPoolExecutor(max_workers=2) as executor:
+                    results = tuple(
+                        executor.map(
+                            lambda args: contender(*args),
+                            (
+                                (first_state.subject.payment_id, first_event),
+                                (second_state.subject.payment_id, second_event),
+                            ),
+                        )
+                    )
+                self.assertEqual(sorted(results), ["conflict", "won"])
+                check = SQLiteFollowupUnitOfWork.open(path)
+                try:
+                    self.assertEqual(task8_counts(check._connection), (1, 1, 1))
+                    self.assertEqual(check._connection.execute("PRAGMA quick_check").fetchone(), ("ok",))
+                    self.assertEqual(check._connection.execute("PRAGMA foreign_key_check").fetchall(), [])
+                finally:
+                    check.close()
+
