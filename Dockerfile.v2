FROM python:3.12-slim

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    V2_SQLITE_PATH=/data/inbox.sqlite3

WORKDIR /app

RUN pip install --no-cache-dir \
      "cryptography>=42.0.0" \
      "fastapi>=0.115.0" \
      "httpx>=0.27.0" \
      "pydantic>=2.8.0" \
      "pytest>=8.0.0" \
      "PyYAML>=6.0.0" \
      "uvicorn>=0.30.0"

COPY . /app

RUN python scripts/check_fasttrack_boundaries.py \
    && python -m compileall -q \
      reservation_boundary \
      reservation_confirmation \
      reservation_domain \
      reservation_execution \
      reservation_followup \
      reservation_lookup \
      v2_adapters \
      v2_application \
      v2_contracts \
      v2_host

RUN addgroup --system --gid 10001 v2 \
    && adduser --system --uid 10001 --ingroup v2 --home /nonexistent --no-create-home v2 \
    && chmod -R a+rX /app \
    && mkdir -p /data \
    && chown -R v2:v2 /data

USER 10001:10001
VOLUME ["/data"]
EXPOSE 8080

ENTRYPOINT ["python", "-m", "v2_host.api_main"]
