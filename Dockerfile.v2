FROM python:3.12-slim AS runtime

ARG VCS_REF=unknown
ARG BUILD_DATE=unknown
ARG VERSION=0.8.0

LABEL org.opencontainers.image.title="Chapada Agente V2" \
      org.opencontainers.image.description="Standalone fenced reservation and conversation runtime" \
      org.opencontainers.image.version="$VERSION" \
      org.opencontainers.image.revision="$VCS_REF" \
      org.opencontainers.image.created="$BUILD_DATE" \
      org.opencontainers.image.source="https://github.com/nesquena/agente-v2"

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PYTHONPATH=/app \
    V2_SQLITE_PATH=/data/inbox.sqlite3

WORKDIR /app

RUN pip install --no-cache-dir \
      "hermes-agent==0.19.0" \
      "fastapi==0.133.1" \
      "httpx==0.28.1" \
      "pydantic==2.13.4" \
      "PyYAML==6.0.3" \
      "cryptography==46.0.7" \
      "uvicorn==0.41.0"

COPY reservation_boundary /app/reservation_boundary
COPY reservation_confirmation /app/reservation_confirmation
COPY reservation_domain /app/reservation_domain
COPY reservation_execution /app/reservation_execution
COPY reservation_followup /app/reservation_followup
COPY reservation_lookup /app/reservation_lookup
COPY v2_adapters /app/v2_adapters
COPY v2_application /app/v2_application
COPY v2_contracts /app/v2_contracts
COPY v2_host /app/v2_host
COPY config/cerebro_faq.yaml /app/config/cerebro_faq.yaml
COPY config/v2_luna_system_prompt.txt /app/config/v2_luna_system_prompt.txt

RUN python -m compileall -q \
      reservation_boundary \
      reservation_confirmation \
      reservation_domain \
      reservation_execution \
      reservation_followup \
      reservation_lookup \
      v2_adapters \
      v2_application \
      v2_contracts \
      v2_host \
    && addgroup --system --gid 10001 v2 \
    && adduser --system --uid 10001 --ingroup v2 --home /nonexistent --no-create-home v2 \
    && chmod -R a+rX /app \
    && mkdir -p /data \
    && chown -R v2:v2 /data

USER 10001:10001
VOLUME ["/data"]
EXPOSE 8080

ENTRYPOINT ["python", "-m", "v2_host.api_main"]
